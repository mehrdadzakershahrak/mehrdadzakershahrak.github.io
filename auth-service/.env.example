PORT=8787
NODE_ENV=development

# Google Identity Services
GOOGLE_CLIENT_ID=YOUR_GOOGLE_WEB_CLIENT_ID.apps.googleusercontent.com

# Session cookie signing secret. Use a long random value in production.
SESSION_SECRET=replace-this-with-a-long-random-secret
SESSION_TTL_SECONDS=1209600
AUTH_COOKIE_NAME=mdz_session

# Production: set COOKIE_DOMAIN=.mehrdadzaker.com and COOKIE_SECURE=true
COOKIE_DOMAIN=
COOKIE_SECURE=false

# Comma-separated list of browser origins allowed to call this service.
ALLOWED_ORIGINS=http://127.0.0.1:4000,http://localhost:4000,https://www.mehrdadzaker.com,https://mehrdadzaker.com

# Optional: map demo ids to upstream endpoints.
# Example:
# DEMO_CHAT_ENDPOINTS_JSON={"legal":"https://example.com/legal","finance":"https://example.com/finance"}
DEMO_CHAT_ENDPOINTS_JSON={}
