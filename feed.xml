---
layout: null
permalink: /feed.xml
---
<?xml version="1.0" encoding="UTF-8"?>
<rss version="2.0" xmlns:atom="http://www.w3.org/2005/Atom">
  <channel>
    <title>{{ site.title | xml_escape }}</title>
    <description>{{ site.description | xml_escape }}</description>
    <link>{{ site.url }}/</link>
    <atom:link href="{{ '/feed.xml' | absolute_url }}" rel="self" type="application/rss+xml" />
    <language>{{ site.locale | default: "en" | replace: "_", "-" }}</language>
    <lastBuildDate>{{ site.time | date_to_rfc822 }}</lastBuildDate>
    {% assign ai_feed_items = site.ai_material | sort: "date" | reverse %}
    {% for item in ai_feed_items limit: 20 %}
      <item>
        <title>{{ item.title | xml_escape }}</title>
        <link>{{ item.url | absolute_url }}</link>
        <guid isPermaLink="true">{{ item.url | absolute_url }}</guid>
        {% if item.date %}<pubDate>{{ item.date | date_to_rfc822 }}</pubDate>{% endif %}
        <description>{{ item.excerpt | default: item.description | markdownify | strip_html | strip_newlines | normalize_whitespace | xml_escape }}</description>
      </item>
    {% endfor %}
  </channel>
</rss>
